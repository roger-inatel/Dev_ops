# ============================================================
# AdotaPet - exemplo de variaveis de ambiente
# Copie este arquivo para .env e ajuste antes de subir o stack:
#   cp .env.example .env
# Esses valores sao lidos pelo docker-compose.yml na raiz.
# ============================================================

# --- MySQL (servico mysql do compose) ---
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=adotapet
# Porta exposta no HOST. Default 3307 (evita conflito com MySQL nativo na 3306).
MYSQL_HOST_PORT=3307

# --- Backend (NestJS) ---
# JWT_SECRET e obrigatorio - o compose interrompe se nao estiver setado.
# Gere algo forte em producao (ex.: openssl rand -hex 32).
JWT_SECRET=troque_este_segredo_em_producao
# Porta exposta no HOST. Default 3010 (evita 3000, comum em outros projetos).
BACKEND_HOST_PORT=3010

# --- Frontend (Next.js) ---
# Porta exposta no HOST. Default 3011.
FRONTEND_HOST_PORT=3011
# URL publica do backend (lida no browser do usuario). Por padrao usa a porta
# acima; pode sobrescrever se for atras de um proxy reverso.
NEXT_PUBLIC_API_URL=http://localhost:3010

# --- Pipeline / Jenkins (NP2 S07) ---
# Destino do e-mail de notificacao do pipeline (NAO hardcoded em codigo).
# Pode ser uma lista separada por virgula.
NOTIFY_EMAIL=devops@time.local

# SMTP - quando o pipeline roda no compose principal, aponta para o servico mailhog.
# Quando o Jenkins (docker-compose.jenkins.yml) precisar mandar via mailhog,
# use SMTP_HOST=host.docker.internal:1025 ou conecte ambos a uma rede comum.
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=jenkins@adotapet.local

# Portas do MailHog no HOST (caso conflite com algum SMTP local).
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
