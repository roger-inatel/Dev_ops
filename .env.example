# ============================================================
# AdotaPet - exemplo de variaveis de ambiente
# Copie este arquivo para .env e ajuste antes de subir o stack:
#   cp .env.example .env
# Esses valores sao lidos pelo docker-compose.yml na raiz.
# ============================================================

# --- MySQL (servico mysql do compose) ---
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=adotapet

# --- Backend (NestJS) ---
# JWT_SECRET e obrigatorio - o compose interrompe se nao estiver setado.
# Gere algo forte em producao (ex.: openssl rand -hex 32).
JWT_SECRET=troque_este_segredo_em_producao

# --- Frontend (Next.js) ---
# URL publica do backend (lida no browser do usuario).
NEXT_PUBLIC_API_URL=http://localhost:3000
