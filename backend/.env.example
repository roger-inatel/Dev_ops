# ============================================================
# AdotaPet Backend - exemplo de variaveis de ambiente
# Copie para .env (mesma pasta) antes de rodar o backend local:
#   cp .env.example .env        (Linux/macOS)
#   Copy-Item .env.example .env (Windows PowerShell)
# Para subir tudo via docker-compose, use o .env.example da raiz.
# ============================================================

# Conexao com o MySQL. Em dev local (banco subido com `docker compose up -d mysql`):
DATABASE_URL="mysql://root:root@localhost:3306/adotapet"

# Segredo do JWT. NAO use este valor em producao.
JWT_SECRET="troque_este_segredo_em_producao"

# Porta do servidor HTTP (Swagger fica em /docs).
PORT=3000
